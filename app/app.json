{
  "expo": {
    "name": "OpenSSH",
    "slug": "openssh",
    "version": "1.0.0",
    "description": "SSH into any machine from your phone — no port forwarding, no VPN. Connect through a smart relay from anywhere.",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F2F2F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amritrai.openssh"
    },
    "android": {
      "package": "com.amritrai.openssh",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#7B6CF6",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "2f5cd8d0-a002-45d5-be05-8f6eae3a9d5b"
      }
    },
    "owner": "amritrai"
  }
}
